		}
		{
			dependencies: ["61FF5795C584957A"]
			description: ["You are probably tired of crushing metals and smelting blends by now. Thankfully, you can now use the Alloy Smelter to make all of your alloys! It's pretty slow but at least it can run in the background."]
			id: "55ACAF8733D01A33"
			subtitle: "Tinkers Construct at Home"
