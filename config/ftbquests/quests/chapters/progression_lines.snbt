					type: "item"
				}
				{
					id: "17366CB4086C429F"
					title: "Automated"
					type: "checkmark"
				}
			]
			title: "Arboreal Extraction"
			x: 3.0d
			y: 2.5d
		}
		{
			dependencies: ["25B2134258088C7F"]
			description: [
				"Latex is made from hooking up an arboreal extractor to a jungle or rubberwood (NOT just rubber!) tree."
