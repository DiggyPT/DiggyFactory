	quests: [
		{
			dependencies: ["1790658601A1E187"]
			description: ["The &lWiremill&r is probably the first machine that you'll make in &7Low Voltage&r. It can turn 1 ingot into 2 wires, so it'll make a LOT of recipes much easier!"]
			id: "5D74D6F0E45BC71C"
			subtitle: "Wire you doing this?"
