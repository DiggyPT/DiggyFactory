		}
		{
			dependencies: ["1790658601A1E187"]
			description: ["Make a &lLathe&r to be able to turn an ingot into 2 rods. This is more efficient than doing it by hand with a file, which gave you 1 rod per ingot."]
			id: "6389E73010F05D4B"
			subtitle: "Rod Inserter"
			tasks: [{
				id: "078B119206EC21C4"
				item: "gtceu:lv_lathe"
