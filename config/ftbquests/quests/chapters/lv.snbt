			}]
			x: 2.0d
			y: -2.0d
		}
		{
			dependencies: ["1790658601A1E187"]
			description: ["The &lArc Furnace&r is a machine that can recycle other machines into most of their constituent metals using oxygen. However, it can also make &aGlass&r super efficiently and make &6Annealed Copper&r, which will be used for a bunch of new recipes. "]
			id: "21751E823716D187"
			subtitle: "Recycling Bin"
			tasks: [{
				id: "26CB506557C85D3C"
				item: "gtceu:lv_arc_furnace"
