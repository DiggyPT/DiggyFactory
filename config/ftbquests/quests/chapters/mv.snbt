			y: 1.0d
		}
		{
			dependencies: [
				"5109EA2277F57FF7"
				"687CF89B04511124"
			]
			description: ["With the &bMV Mixer&r, you can cut silicon boules into &lsilicon wafers&r, which are needed to make &6integrated circuits&r."]
			id: "7E3663D31B94E601"
			subtitle: "Mmm yummy wafers"
