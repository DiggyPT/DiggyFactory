			y: -3.5d
		}
		{
			dependencies: [
				"458499E306C79E7F"
				"3121B45962AB1250"
			]
			dependency_requirement: "one_completed"
			description: [
				"Eventually you will need to turn in fluids for quests. You can't use buckets or cells or fluid storage, so how do you do it?"
				""
				"The answer is &lTask Screens&r. You can make them in various sizes, and when placed down you can right click them and select the task you want to turn in the fluid for. Unfortunately this consumes the fluid. Sorry...."
				"{@pagebreak}"
				"&9Note:&r You can unlock this quest by unlocking any one of its dependencies!"
			]
			id: "1947B8EAF77F54A6"
			shape: "pentagon"
			subtitle: "How would that work?"
			tasks: [{
				id: "7F0B0F950B6BBB3C"
